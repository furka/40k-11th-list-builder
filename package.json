{
  "name": "40k-11th-list-builder",
  "private": true,
  "version": "1.0.14",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "mfm:scrape": "node --env-file-if-exists=.env scripts/scrape-mfm-11th/index.mjs",
    "mfm:scrape:refresh": "node --env-file-if-exists=.env scripts/scrape-mfm-11th/index.mjs --refresh",
    "factionpack:scrape": "node --env-file-if-exists=.env scripts/scrape-faction-pack-11th/index.mjs",
    "factionpack:scrape:refresh": "node --env-file-if-exists=.env scripts/scrape-faction-pack-11th/index.mjs --refresh",
    "factionpack:errata": "node --env-file-if-exists=.env scripts/scrape-faction-pack-11th/scrape-errata-keywords.mjs",
    "factionpack:discover-urls": "node scripts/scrape-faction-pack-11th/discover-faction-pack-urls.mjs",
    "bsdata:scrape": "node scripts/scrape-bsdata-keywords/index.mjs",
    "bsdata:scrape:refresh": "node scripts/scrape-bsdata-keywords/index.mjs --refresh",
    "bsdata:enhancements": "node scripts/scrape-bsdata-enhancements/index.mjs",
    "bsdata:enhancements:refresh": "node scripts/scrape-bsdata-enhancements/index.mjs --refresh",
    "bsdata:wargear": "node scripts/scrape-bsdata-wargear/index.mjs",
    "bsdata:wargear:refresh": "node scripts/scrape-bsdata-wargear/index.mjs --refresh",
    "bsdata:prune-overrides": "node scripts/audit-and-prune-overrides.mjs"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "uuid": "^14.0.1",
    "vite-svg-loader": "^5.1.1",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@pinia/testing": "^1.0.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "fast-xml-parser": "^5.9.3",
    "jsdom": "^29.1.1",
    "pdfjs-dist": "^6.0.227",
    "playwright": "^1.61.1",
    "sass": "^1.101.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
